<?xml version="1.0" encoding="UTF-8"?>
<launch>

  <arg name="glfw_render" default="0"/>
  <arg name="controller_list" default=""/>
  <arg name="model" default=""/>

  <node 
    pkg="lockstep_sim" 
    exec="lockstep_sim" 
    name="sim" 
    ros_args="--log-level info"
    output="screen">

    <param name="glfw_render" value="$(var glfw_render)"/>
    <param name="controller_list" value="$(var controller_list)"/>
    <param name="model_name" value="$(var model)"/>


  </node>

  <include file="$(find-pkg-share foxglove_bridge)/launch/foxglove_bridge_launch.xml" />

  <executable
    cmd="foxglove-studio"
    name="foxglove_studio"
    output="screen"
  />

</launch>