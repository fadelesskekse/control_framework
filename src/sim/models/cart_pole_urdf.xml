<?xml version="1.0"?>
<robot name="cart_pole">

  <!-- Materials -->
  <material name="default_geom">
    <color rgba="0.8 0.6 0.4 1"/>
  </material>

  <material name="ground_red">
    <color rgba="0.9 0.0 0.0 1"/>
  </material>

  <!-- World/root link -->
  <link name="world"/>

  <!-- Ground plane approximation.
       MJCF plane is effectively infinite for physics/visualization.
       URDF has no plane primitive, so this uses a thin box. -->
  <link name="ground_link">
    <visual>
      <origin xyz="0 0 -0.005" rpy="0 0 0"/>
      <geometry>
        <box size="2.0 2.0 0.01"/>
      </geometry>
      <material name="ground_red"/>
    </visual>
  </link>

  <joint name="world_to_ground_joint" type="fixed">
    <parent link="world"/>
    <child link="ground_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Cart body.
       MJCF:
         body pos="0 0 0.0508"
         geom type="box" size=".1016 .0762 .0508"
       Important:
         MJCF box size is half-size.
         URDF box size is full-size.
       Therefore:
         2 * .1016 = 0.2032
         2 * .0762 = 0.1524
         2 * .0508 = 0.1016
  -->
  <link name="cart">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.2032 0.1524 0.1016"/>
      </geometry>
      <material name="default_geom"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.2032 0.1524 0.1016"/>
      </geometry>
    </collision>
  </link>

  <!-- MJCF:
       <joint type="slide" axis="1 0 0"/>
       This becomes a URDF prismatic joint.
  -->
  <joint name="cart_joint" type="prismatic">
    <parent link="world"/>
    <child link="cart"/>
    <origin xyz="0 0 0.0508" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-5.0" upper="5.0" effort="1000.0" velocity="100.0"/>
  </joint>

  <!-- Pole link.
       MJCF:
         body pos="0 0 .0254"
         geom type="capsule" size="0.01" fromto="0 0 0 0 0 .3"

       URDF has no capsule primitive, so this uses:
         - cylinder of radius 0.01, length 0.3
         - sphere at bottom
         - sphere at top
  -->
  <link name="pole">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.3"/>
      </geometry>
      <material name="default_geom"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.3"/>
      </geometry>
    </collision>

    <!-- Bottom cap approximation -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <material name="default_geom"/>
    </visual>

    <!-- Top cap approximation -->
    <visual>
      <origin xyz="0 0 0.3" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <material name="default_geom"/>
    </visual>
  </link>

  <!-- MJCF:
       body pos="0 0 .0254"
       joint type="hinge" axis="0 -1 0"

       This becomes a URDF continuous joint.
  -->
  <joint name="pole_joint" type="continuous">
    <parent link="cart"/>
    <child link="pole"/>
    <origin xyz="0 0 0.0254" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
  </joint>

  <!-- Tip mass sphere.
       MJCF:
         body pos="0 0 .3"
         geom type="sphere" mass=".2" size=".025"
  -->
  <link name="pole_tip">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
      <material name="default_geom"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
    </collision>
  </link>

  <joint name="pole_to_tip_joint" type="fixed">
    <parent link="pole"/>
    <child link="pole_tip"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
  </joint>

</robot>